# 天玑 · 环境变量配置示例
#
# 复制这个文件为 .env（同目录），填入真实值。
# .env 已经在 .gitignore 里，不会被提交进仓库。
#
# 验证某个 key 是否有效，用 scripts/security/verify_key.sh <name>，
# 不要在代码里手动 print 出来确认。

# --- 汇率采集器 (fx_collector.py) ---
FRED_API_KEY=
EXCHANGERATE_API_KEY=

# --- Reddit消费者洞察 (reddit_collector.py) ---
# 注册: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Telegram行业监控 (telegram_collector.py) ---
# 注册: Telegram搜索 @BotFather
TELEGRAM_BOT_TOKEN=

# --- YouTube趋势 (youtube_collector.py) ---
# 注册: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# --- 按需搜索聚合 (marketing_intel / reputation_capital / seo_geo 用到的AnySearch/Tavily) ---
TAVILY_API_KEY=
